# Secrets / env
.env
.env.*
*.pem
*.key
*.p12

# Node / build
node_modules/
.next/
dist/
build/
coverage/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Client-sensitive exports
**/logs/*.log
**/logs/*.json
**/deliverables/*.zip
**/deliverables/*.patch

# Runtime state
/runtime/*
!/runtime/.gitkeep
!/runtime/replies/
/runtime/replies/*
!/runtime/replies/.gitkeep
!/runtime/rehearsal/
/runtime/rehearsal/*
!/runtime/rehearsal/.gitkeep
!/runtime/rehearsal/README.ja.md

# Case data
/ops/cases/open/*
!/ops/cases/open/.gitkeep
/ops/cases/closed/*
!/ops/cases/closed/.gitkeep

# Windows ADS
*:Zone.Identifier
