--- a/src/lib/billing/applySubscriptionUpdate.ts
+++ b/src/lib/billing/applySubscriptionUpdate.ts
@@ -1,5 +1,10 @@
+// event.id で重複排除。同一イベントの二重適用を防ぐ
 export async function applySubscriptionUpdate({ eventId, customerId }: Params) {
+  if (processedEventIds.has(eventId)) {
+    return;
+  }
+
   const member = await findMemberByCustomerId(customerId);
   await updateMemberPlan(member.id, "pro");
+  processedEventIds.add(eventId);
 }
